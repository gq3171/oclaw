{
  "gateway": {
    "port": 8080,
    "bind": "0.0.0.0",
    "auth": {
      "mode": "token",
      "token": "${OCLAWS_GATEWAY_AUTH_TOKEN}"
    }
  },

  "logging": {
    "level": "info"
  },

  "models": {
    "providers": {
      "minimax": {
        "provider": "anthropic",
        "apiKey": "${OCLAWS_PROVIDER_MINIMAX_API_KEY}",
        "baseUrl": "https://api.minimaxi.com/anthropic",
        "model": "MiniMax-Text-01",
        "maxTokens": 4096,
        "temperature": 0.7
      }
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${OCLAWS_TELEGRAM_BOT_TOKEN}"
    },
    "feishu": {
      "enabled": true,
      "appId": "${OCLAWS_FEISHU_APP_ID}",
      "appSecret": "${OCLAWS_FEISHU_APP_SECRET}"
    }
  },

  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": false,
    "evaluateEnabled": true,
    "cdpUrl": "ws://localhost:9222",
    "ssrfPolicy": {
      "allowPrivateNetwork": false,
      "allowedHostnames": []
    }
  },

  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 3,
    "store": "sqlite",
    "webhook": "http://localhost:8080/webhooks/telegram",
    "webhookToken": "${OCLAWS_GATEWAY_AUTH_TOKEN}"
  }
}
