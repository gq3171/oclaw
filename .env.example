# ============================================================
# OpenClaw (oclaw) 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ---- 网关 (Gateway) ----
OCLAWS_GATEWAY_PORT=8080
OCLAWS_GATEWAY_BIND=0.0.0.0
OCLAWS_GATEWAY_URL=http://127.0.0.1:8081

# ---- 网关认证 ----
OCLAWS_GATEWAY_AUTH_TOKEN=your-random-token-here
OCLAWS_GATEWAY_AUTH_PASSWORD=your-password-here

# ---- 日志 ----
OCLAWS_LOG_LEVEL=info

# ---- LLM Provider API Keys ----
# 格式: OCLAWS_PROVIDER_{NAME}_API_KEY (NAME 对应 config.json 中 models.providers 的 key，大写)
OCLAWS_PROVIDER_MINIMAX_API_KEY=your-minimax-api-key
OCLAWS_PROVIDER_OPENAI_API_KEY=your-openai-api-key

# ---- Telegram ----
OCLAWS_TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# ---- Discord ----
OCLAWS_DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_PUBLIC_KEY=your-discord-ed25519-public-key

# ---- Slack ----
OCLAWS_SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
OCLAWS_SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_SIGNING_SECRET=your-slack-webhook-signing-secret

# ---- 飞书 (Feishu / Lark) ----
OCLAWS_FEISHU_APP_ID=your-feishu-app-id
OCLAWS_FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_ENCRYPT_KEY=your-feishu-encrypt-key

# ---- Webchat ----
OCLAWS_WEBCHAT_PASSWORD=your-webchat-password

# ---- 工具 (Tools) ----
FIRECRAWL_API_KEY=your-firecrawl-api-key
BRAVE_API_KEY=your-brave-search-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key
# 设置此变量允许 fetch 工具访问内网地址 (慎用)
# OCLAWS_ALLOW_PRIVATE_FETCH=1
